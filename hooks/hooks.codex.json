{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__baz__",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CODEX_PLUGIN_DIR}/hooks/post-tool-use.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CODEX_PLUGIN_DIR}/hooks/session-end.js\""
          }
        ]
      }
    ]
  }
}
