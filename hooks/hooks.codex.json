{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CODEX_PLUGIN_DIR}/hooks/session-start.js\" codex"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__baz__",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CODEX_PLUGIN_DIR}/hooks/post-tool-use.js\""
          }
        ]
      },
      {
        "matcher": "apply_patch|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CODEX_PLUGIN_DIR}/hooks/plan-complete.js\" codex"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CODEX_PLUGIN_DIR}/hooks/session-end.js\""
          }
        ]
      }
    ]
  }
}
