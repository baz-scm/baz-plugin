{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/hooks/session-start.js\" cursor"
      }
    ],
    "postToolUse": [
      {
        "matcher": "mcp__baz__",
        "command": "node \"${CURSOR_PLUGIN_ROOT}/hooks/post-tool-use.js\""
      },
      {
        "matcher": "edit_file|write_file|Write|Edit",
        "command": "node \"${CURSOR_PLUGIN_ROOT}/hooks/plan-complete.js\" cursor"
      }
    ],
    "stop": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/hooks/stop-token-tally.js\""
      }
    ],
    "sessionEnd": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/hooks/session-end.js\""
      }
    ]
  }
}
